# crypto-gateway example configuration.
# Each entrypoint reads its runtime's env (process.env / env binding / Deno.env)
# and validates the result with config.schema.ts (Phase 1 deliverable).

# ---- Adapter selection ----
DB_ADAPTER=libsql                      # d1 | libsql | pg
CACHE_ADAPTER=memory                   # cf-kv | redis | memory | libsql-table
JOBS_ADAPTER=promise-set               # wait-until | promise-set | queue
PRICE_ADAPTER=static-peg               # alchemy | coingecko | static-peg
DETECTION_STRATEGY=rpc-poll            # alchemy-notify | rpc-poll | tron-grid-poll

# ---- Secrets (validated at boot) ----
MASTER_SEED=
ADMIN_KEY=
SWEEP_MASTER_KEY=

# ---- Providers ----
ALCHEMY_API_KEY=
ALCHEMY_NOTIFY_TOKEN=

# ---- DB (when DB_ADAPTER != d1) ----
DATABASE_URL=file:./local.db
DATABASE_TOKEN=

# ---- Cache (when CACHE_ADAPTER = redis) ----
REDIS_URL=

# ---- Server ----
PORT=8787
