// Cloudflare Workers deployment config.
//
// >>> For local dev / deployment, copy this file to `wrangler.jsonc` and fill
//     in your own D1 + KV ids (the real file is gitignored). <<<
//
// First-time setup:
//   cp wrangler.jsonc.example wrangler.jsonc
//   npx wrangler d1 create crypto-gateway-dev           # paste database_id below
//   # Apply every SQL file in migrations/ in order against the REMOTE D1.
//   # Workers cannot read the filesystem at runtime, so migrations are applied
//   # CLI-side. Omitting --remote writes only to the local .wrangler sandbox,
//   # which is fine for `wrangler dev` but NOT for a deployed worker:
//   for f in migrations/*.sql; do npx wrangler d1 execute crypto-gateway-dev --remote --file="$f"; done
//   # For local dev against `wrangler dev`, repeat without --remote:
//   # for f in migrations/*.sql; do npx wrangler d1 execute crypto-gateway-dev --file="$f"; done
//   npx wrangler kv namespace create CACHE              # paste id below
//   npx wrangler secret put MASTER_SEED                 # BIP39 mnemonic
//   npx wrangler secret put ADMIN_KEY                   # random 32+ chars
//   npx wrangler secret put CRON_SECRET                 # optional, only for /internal/cron/tick
//   npx wrangler secret put ALCHEMY_API_KEY                 # optional, but recommended (per-app JSON-RPC key)
//   npx wrangler secret put ALCHEMY_NOTIFY_TOKEN            # optional; required for /admin/bootstrap/alchemy-webhooks
//                                                           # NOT the same as ALCHEMY_API_KEY — get it from
//                                                           # https://dashboard.alchemy.com/apps/latest/webhooks
//                                                           # (top of page: "Auth Token"). Using the API key
//                                                           # here returns 401 from Alchemy's webhook admin API.
//                                                           # (Old name ALCHEMY_AUTH_TOKEN still accepted for one release.)
//   npx wrangler secret put GATEWAY_PUBLIC_URL              # required for webhook bootstrap — e.g. https://your-worker.workers.dev
//
// Optional price-oracle + alerting knobs (see README "Price oracle fallback
// chain" and "Log shipping + alerting"):
//   npx wrangler secret put COINGECKO_API_KEY               # optional; raises CoinGecko rate budget (keyless free tier works too)
//   npx wrangler secret put COINCAP_API_KEY                 # optional; raises CoinCap rate budget
//   # Set these as plain vars (not secrets) via [vars] below if you want to
//   # disable individual providers or pick a non-default PRICE_ADAPTER:
//   #   PRICE_ADAPTER=coingecko|alchemy|static-peg
//   #   COINGECKO_PLAN=demo|pro
//   #   DISABLE_COINGECKO=1 / DISABLE_COINCAP=1 / DISABLE_BINANCE=1 / DISABLE_ALCHEMY=1
//   npx wrangler secret put ALERT_WEBHOOK_URL               # optional; error/fatal logs POSTed here (30/min rate-limit, JSON body)
//   npx wrangler secret put ALERT_WEBHOOK_AUTH_HEADER       # optional; Authorization header value for ALERT_WEBHOOK_URL
//
// When a new migration is added (e.g. `migrations/0002_foo.sql`): re-run the
// loop above. D1 has no runtime filesystem access, so the wrangler CLI is the
// canonical migration applier for Workers deployments. Node / Deno run the
// migration-runner at boot and apply any new files automatically.
//
// Deploy:
//   npx wrangler deploy -e dev
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "crypto-gateway",
  "main": "src/entrypoints/worker.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  // Scheduled cron — runs every minute. The worker entrypoint's `scheduled`
  // handler invokes pollPayments + confirmTransactions + executeReservedPayouts
  // + confirmPayouts in sequence. Runtime stays alive via waitUntil.
  "triggers": {
    "crons": ["* * * * *"]
  },

  // D1 database binding. See setup steps above; paste your `database_id` here.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "crypto-gateway-dev",
      "database_id": "REPLACE_WITH_D1_ID"
    }
  ],

  // KV namespace for CacheStore. See setup steps above; paste your `id` here.
  // Add `preview_id` as well if you run `wrangler dev`.
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "REPLACE_WITH_KV_ID"
    }
  ],

  // Cloudflare built-in rate-limit bindings. One entry per scope — each
  // binding is ONE (limit, period) pair enforced atomically at the edge,
  // free, with no invocation cost on our side. Scopes map to the prefix
  // used by the middleware (`rateLimit({ scope: "..." })` in routes).
  //
  // namespace_id: any unique uint32 per binding within this account; the
  // values below are arbitrary but stable — keep them in sync across envs
  // so a rolling deploy doesn't flip buckets. `simple.limit` / `simple.period`
  // should track the RATE_LIMIT_*_PER_MINUTE vars below (those feed the
  // middleware headers; these enforce the actual cap).
  //
  // Any binding you omit falls back to the KV-backed limiter (the
  // cacheBackedRateLimiter adapter), which has a documented over-admit
  // risk under burst. Declare all four for strict production limits.
  "ratelimits": [
    { "name": "RATE_LIMIT_ADMIN",           "namespace_id": "4001", "simple": { "limit": 30,   "period": 60 } },
    { "name": "RATE_LIMIT_CHECKOUT",        "namespace_id": "4002", "simple": { "limit": 60,   "period": 60 } },
    { "name": "RATE_LIMIT_WEBHOOK_INGEST",  "namespace_id": "4003", "simple": { "limit": 300,  "period": 60 } },
    { "name": "RATE_LIMIT_MERCHANT_API",    "namespace_id": "4004", "simple": { "limit": 1000, "period": 60 } }
  ],

  // Public env vars. Secrets (MASTER_SEED, ADMIN_KEY, CRON_SECRET,
  // ALCHEMY_NOTIFY_TOKEN, SECRETS_ENCRYPTION_KEY, ...) are set via
  // `wrangler secret put <NAME>` and do NOT go here.
  "vars": {
    "DB_ADAPTER": "d1",
    "CACHE_ADAPTER": "cf-kv",
    "JOBS_ADAPTER": "wait-until"
  },

  // Named per-environment overrides. Start with a dev env; staging / production
  // get their own D1 + KV ids to keep data isolated.
  "env": {
    "dev": {
      "name": "crypto-gateway-dev",
      "vars": { "ENV": "dev" }
    }
  },

  "observability": {
    "enabled": true
  }
}
